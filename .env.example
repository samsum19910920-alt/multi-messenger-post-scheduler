# Flask Configuration
FLASK_APP=app.py
FLASK_ENV=development
SECRET_KEY=your-secret-key-here-change-in-production
DEBUG=False

# Database
DATABASE_URL=sqlite:///app.db

# SMS Service (Faraz SMS)
FARAZ_SMS_API_URL=https://api.farazsms.com/
FARAZ_SMS_API_KEY=your-faraz-sms-api-key
FARAZ_SMS_API_USERNAME=your-faraz-sms-username

# Messengers API Keys
RUBIKA_BOT_TOKEN=your-rubika-bot-token
BALE_BOT_TOKEN=your-bale-bot-token
EITAA_BOT_TOKEN=your-eitaa-bot-token
SOROOSH_BOT_TOKEN=your-soroosh-bot-token

# Storage
STORAGE_PATH=/tmp/media  # For testing
MAX_FILE_SIZE=52428800   # 50MB in bytes

# Security
JWT_SECRET_KEY=your-jwt-secret-key-here
JWT_EXPIRATION_HOURS=24
OTP_EXPIRATION_MINUTES=5
OTP_MAX_ATTEMPTS=3

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# Admin Panel
ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=your-hashed-password-here

# Auto-delete old files (in days)
AUTO_DELETE_AFTER_DAYS=7
